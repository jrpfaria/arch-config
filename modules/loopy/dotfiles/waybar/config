{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 5,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    // "modules-right": ["custom/updates", "group/hardware", "group/sysinfo", "network", "bluetooth", "tray"],
    "modules-right": ["group/hardware", "group/sysinfo", "network", "bluetooth", "tray"],
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "custom/cputemp",
            "custom/gputemp",
            "memory"
        ]
    },
    "group/sysinfo": {
	"orientation": "horizontal",
	"modules": ["hyprland/language", "wireplumber"]
    },

    "hyprland/workspaces": {
        "format": "<span size='large'>{icon}</span>",
        "on-click": "activate",
        "format-icons": {
            "active":  " \uf1b0 ",
            "default": " ♥ ",
            "empty":   " ○ "
        },
        "icon-size": 10,
        "sort-by-number": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "clock": {
        "format": "{:%H:%M}  ",
        "format-alt": "{:%A, %b %d, %Y (%R)}  ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar-weeks-pos": "right",
        "today-format": "<span color='#ff6699'><b><u>{}</u></b></span>",
        "format-calendar": "<span color='#ecc6d9'><b>{}</b></span>",
        "format-calendar-weeks": "<span color='#99ffdd'><b>W{:%V}</b></span>",
        "format-calendar-weekdays": "<span color='#ffcc66'><b>{}</b></span>",
    },

    "custom/updates": {
        "exec": "scripts/updates/update-checker.sh",
        "interval": 30,
        "return-type": "json",
        "format": "{}",
        "on-click": "ghostty -e update"
    },

    "wireplumber": {
        "interval": 15,
        "format": "\udb81\udd7e {volume}%",
        "max-volume": 100,
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "custom/gputemp": {
        "interval": 15,
        "exec": "sensors | grep -A 6 'amdgpu-pci-0300' | grep 'junction' | awk '{print $2}' | tr -d '+'",
        "format": "󰍹 {}",
        "tooltip-format": "GPU @{}"
    },

    "custom/cputemp": {
        "interval": 15,
        "exec": "sensors | grep -A 3 'k10temp-pci-00c3' | grep 'Tctl' | awk '{print $2}' | tr -d '+'",
        "format": "\uf4bc {}",
        "tooltip-format": "CPU @{}"
    },

    "memory": {
        "interval": 15,
        "format": " {used:0.1f}G"
    },

     "hyprland/language": {
        "format": "⌨ {}",
        "format-pt": "pt",
        "format-en": "us"
    }, 

    "network": {
    	"on-click": "exec ghostty -e wifitui --theme=$HOME/.config/wifitui/theme.toml",
        "format": "",
        "format-ethernet": "\udb83\udc9d",
        "format-wifi": "{icon}",
        "format-disconnected": "\udb83\udc9c",
        "format-icons": ["\udb82\udd2f", "\udb82\udd1f", "\udb82\udd22", "\udb82\udd25", "\udb82\udd28"],
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Disconnected"
    },

    "bluetooth": {
        "on-click": "exec ghostty -e bluetui",
        "format": "\udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 16
    }
}
